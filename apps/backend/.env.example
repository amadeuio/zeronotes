# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zeronotes
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Alternative: Use a full database URL instead of individual params
DB_URL=postgresql://your_db_user:your_db_password@localhost:5432/zeronotes

# Server Configuration
PORT=3000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d