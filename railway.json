{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "corepack enable && corepack prepare pnpm@10.24.0 --activate && pnpm install && pnpm exec turbo build --filter=@zeronotes/backend",
    "watchPatterns": ["/apps/backend/**"]
  },
  "deploy": {
    "runtime": "V2",
    "startCommand": "pnpm --filter=@zeronotes/backend start",
    "sleepApplication": false,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
